# Production env for docker-compose.prod.yml — copy to .env and fill in.
#   cp .env.prod.example .env

# ---- image source (GHCR, published by CI) ----
# Owner must be lowercase. Override TAG to pin a specific build (commit SHA).
ASETICLE_IMAGE=ghcr.io/lxzlocus/aseticle
TAG=latest

# ---- host port for the frontend (only published port) ----
# Pick one free on your host (e.g. behind your reverse proxy).
FRONTEND_PORT=49513

# ---- MySQL (REQUIRED — no defaults) ----
MYSQL_DATABASE=aseticle
MYSQL_USER=aseticle
MYSQL_PASSWORD=change-me-strong
MYSQL_ROOT_PASSWORD=change-me-strong-root

# ---- security (REQUIRED — generate strong values) ----
# JWT_SECRET:     openssl rand -hex 32
# ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me

# Set true when the frontend is served over HTTPS (reverse proxy / TLS).
COOKIE_SECURE=false
# Public origin(s) the browser uses (comma separated), e.g. https://aseticle.example.com
CORS_ORIGINS=http://localhost:49513

# ---- paper-fetch egress (see DEPLOYMENT.md) ----
# auto = proxy if OUTBOUND_PROXY_URL set, else direct. Set 'direct' to skip the proxy.
PAPER_FETCH_MODE=auto
OUTBOUND_PROXY_URL=http://proxy:8888
# relay mode (phone-home) — leave empty unless using a remote relay:
RELAY_URL=
RELAY_CLIENT_TOKEN=
RELAY_FALLBACK_DIRECT=false

# Optional global SerpApi key (Google Scholar source).
SERPAPI_KEY=
