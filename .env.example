# Copy to .env and adjust. docker-compose reads these.

# --- MySQL ---
MYSQL_DATABASE=aseticle
MYSQL_USER=aseticle
MYSQL_PASSWORD=aseticle
MYSQL_ROOT_PASSWORD=rootpassword

# --- Security ---
# Use a long random string in production.
JWT_SECRET=change-me-in-production
# Fernet key for encrypting BYO API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Set true when serving over HTTPS (Secure cookies).
COOKIE_SECURE=false
ENV=development

# Host port the frontend is published on (container always listens on 3000).
FRONTEND_PORT=49513

# Browser origin(s) allowed by CORS (comma separated).
CORS_ORIGINS=http://localhost:49513,http://localhost:3000

# Optional global SerpApi key (users can also set their own in-app).
SERPAPI_KEY=

# --- Paper-fetch egress -----------------------------------------------------
# mode: auto | direct | proxy | relay
#   auto  = relay if RELAY_URL set, else proxy if OUTBOUND_PROXY_URL set, else direct
PAPER_FETCH_MODE=auto

# proxy mode: forward proxy (bundled tinyproxy). Reachable directly or over a
# Tailscale mesh, e.g. OUTBOUND_PROXY_URL=http://100.x.y.z:8888
OUTBOUND_PROXY_URL=http://proxy:8888

# relay mode (phone-home): for a restricted network with NO inbound / no port
# forwarding. The agent daemon dials OUT to the relay; the backend submits fetch
# jobs to the relay. Enable by running `docker compose --profile relay up` and:
#   PAPER_FETCH_MODE=relay
#   RELAY_URL=http://relay:8080          # backend -> relay (or a public/Tailscale URL)
#   RELAY_FALLBACK_DIRECT=false          # fall back to direct if agent offline
RELAY_URL=
RELAY_FALLBACK_DIRECT=false

# Shared bearer tokens (use long random values in production). Both the relay
# and the two clients (backend, agent) must agree on these.
RELAY_CLIENT_TOKEN=dev-client-token
RELAY_AGENT_TOKEN=dev-agent-token
# Host port the relay is published on (for agents on other machines).
RELAY_PORT=8090
# If the agent should egress via its own local upstream proxy, set this:
AGENT_UPSTREAM_PROXY=
