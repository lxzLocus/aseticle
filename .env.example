# Copy to .env and adjust. docker-compose reads these.

# --- MySQL ---
MYSQL_DATABASE=aseticle
MYSQL_USER=aseticle
MYSQL_PASSWORD=aseticle
MYSQL_ROOT_PASSWORD=rootpassword

# --- Security ---
# Use a long random string in production.
JWT_SECRET=change-me-in-production
# Fernet key for encrypting BYO API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Set true when serving over HTTPS (Secure cookies).
COOKIE_SECURE=false
ENV=development

# Host port the frontend is published on (container always listens on 3000).
FRONTEND_PORT=49513

# Browser origin(s) allowed by CORS (comma separated).
CORS_ORIGINS=http://localhost:49513,http://localhost:3000

# Optional global SerpApi key (users can also set their own in-app).
SERPAPI_KEY=

# Outbound forward proxy for paper-fetching (arXiv / Semantic Scholar / SerpApi /
# publisher pages). Defaults to the bundled proxy daemon. Set empty to connect
# directly, or point at a proxy running inside your institution's network to
# reach paywalled venues (IEEE / ACM):
#   OUTBOUND_PROXY_URL=http://proxy.your-univ.example:8888
OUTBOUND_PROXY_URL=http://proxy:8888
